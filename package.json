{
  "name": "metaverse",
  "version": "1.0.0",
  "description": "A multiplayer metaverse experience",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev:server": "nodemon server/server.js",
    "dev:client": "vite --host",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "mongodb": "^6.3.0",
    "posthog-js": "^1.234.1",
    "simple-peer": "^9.11.1",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.8.1",
    "three": "^0.162.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "vite": "^5.1.4"
  }
}
