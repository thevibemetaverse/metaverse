{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "metaverse-delta.vercel.app" }],
      "destination": "https://www.thevibemetaverse.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
